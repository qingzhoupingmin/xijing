{
  "style_keywords": ["清爽", "专业", "紫金", "优雅", "舒适"],
  "style_concept": "紫金书卷——浅色为底，如翻开的精装书页；紫色为墨，书写故事温度；金色为饰，点缀关键时刻。干净通透，久看不累",
  "theme": "light",
  "colors": {
    "primary": "#7C5CFC",
    "primary_light": "#9B82FC",
    "primary_lighter": "#EDE9FE",
    "primary_dark": "#6344E0",
    "primary_surface": "#F5F3FF",
    "secondary": "#C9984A",
    "secondary_light": "#DDB06E",
    "secondary_dark": "#A87E38",
    "secondary_surface": "#FFFBEB",
    "semantic": {
      "success": "#10B981",
      "success_surface": "#ECFDF5",
      "warning": "#F59E0B",
      "warning_surface": "#FFFBEB",
      "error": "#EF4444",
      "error_surface": "#FEF2F2",
      "info": "#3B82F6",
      "info_surface": "#EFF6FF"
    },
    "neutral": {
      "0": "#FFFFFF",
      "1": "#F9FAFB",
      "2": "#F3F4F6",
      "3": "#E5E7EB",
      "4": "#D1D5DB",
      "5": "#9CA3AF",
      "6": "#6B7280",
      "7": "#374151",
      "8": "#1F2937",
      "9": "#111827"
    },
    "surface": {
      "page": "#F9FAFB",
      "card": "#FFFFFF",
      "card_hover": "#F9FAFB",
      "input": "#FFFFFF",
      "input_focus": "#FFFFFF",
      "overlay": "rgba(0, 0, 0, 0.4)",
      "sidebar": "#FFFFFF",
      "sidebar_active_bg": "#F5F3FF",
      "topbar": "#FFFFFF"
    },
    "gradient": {
      "primary": "linear-gradient(135deg, #7C5CFC 0%, #9B82FC 100%)",
      "primary_gold": "linear-gradient(135deg, #7C5CFC 0%, #C9984A 100%)",
      "gold_shimmer": "linear-gradient(135deg, #C9984A 0%, #DDB06E 50%, #C9984A 100%)",
      "hero_bg": "linear-gradient(180deg, #F5F3FF 0%, #F9FAFB 100%)",
      "sidebar_accent": "linear-gradient(180deg, #7C5CFC 0%, #9B82FC 100%)",
      "card_top_accent": "linear-gradient(90deg, #7C5CFC 0%, #C9984A 100%)"
    }
  },
  "typography": {
    "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif",
    "font_family_mono": "'SF Mono', 'Fira Code', 'Consolas', monospace",
    "scale": {
      "display": 40,
      "h1": 32,
      "h2": 24,
      "h3": 20,
      "h4": 18,
      "body": 16,
      "body_sm": 14,
      "caption": 12
    },
    "line_height": 1.5,
    "line_height_tight": 1.3,
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "base": 4,
    "scale": {
      "xs": 4,
      "sm": 8,
      "md": 12,
      "base": 16,
      "lg": 24,
      "xl": 32,
      "2xl": 48,
      "3xl": 64
    }
  },
  "border_radius": {
    "sm": 4,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "full": "50%"
  },
  "shadows": {
    "none": "none",
    "xs": "0 1px 2px rgba(0, 0, 0, 0.04)",
    "sm": "0 1px 3px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04)",
    "md": "0 4px 6px rgba(0, 0, 0, 0.05), 0 2px 4px rgba(0, 0, 0, 0.04)",
    "lg": "0 10px 15px rgba(0, 0, 0, 0.06), 0 4px 6px rgba(0, 0, 0, 0.04)",
    "xl": "0 20px 25px rgba(0, 0, 0, 0.08), 0 8px 10px rgba(0, 0, 0, 0.04)",
    "primary_glow": "0 4px 14px rgba(124, 92, 252, 0.25)",
    "gold_glow": "0 4px 14px rgba(201, 152, 74, 0.25)"
  },
  "transitions": {
    "fast": "150ms ease",
    "normal": "250ms ease",
    "slow": "350ms ease"
  },
  "z_index": {
    "dropdown": 1000,
    "sticky": 1020,
    "overlay": 1030,
    "modal": 1040,
    "toast": 1050
  },
  "breakpoints": {
    "sm": 640,
    "md": 768,
    "lg": 1024,
    "xl": 1280,
    "2xl": 1440
  }
}
